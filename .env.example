# Copy to .env and adjust as needed

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://benchmark:benchmark@localhost:5432/benchmark

# --- Queue ---
REDIS_URL=redis://localhost:6379

# --- API Server ---
UPLOAD_DIR=./uploads

# --- Worker ---
API_URL=http://localhost:8000
WORKER_ID=worker-1        # change per machine: worker-rig-4090, worker-rig-3080, etc.

# --- Client ---
BENCHMARK_API_URL=http://localhost:8000
